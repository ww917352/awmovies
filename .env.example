# Local docker-compose (matches docker-compose.yml's db service credentials)
DATABASE_URL=postgresql://movies:movies@localhost:5432/movies

# Neon (production/Vercel) — use the pooled connection string from your Neon
# project dashboard, including ?sslmode=require, e.g.:
# DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
